{
  "name": "@dhikanove/plnm-icon-lib",
  "version": "1.0.0",
  "description": "Vue 3 SVG icon library for PLNM — 150+ icons with TypeScript support",
  "homepage": "https://asdsadasds.com",
  "keywords": [
    "vue",
    "vue3",
    "icons",
    "svg",
    "icon-library",
    "typescript",
    "plnm"
  ],
  "license": "MIT",
  "author": "dhikanove",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhikanove/PLNMIconLib"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build --mode lib",
    "build-demo": "vite build",
    "prepublishOnly": "npm run build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.1.3",
    "typescript": "^5.5.3",
    "vite": "^6.4.1",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.4"
  }
}
